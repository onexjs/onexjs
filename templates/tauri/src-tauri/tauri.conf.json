{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "identifier": "com.{{PROJECT_SLUG}}.app",
  "build": {
    "beforeDevCommand": "{{TAURI_DEV_COMMAND}}",
    "beforeBuildCommand": "{{TAURI_BUILD_COMMAND}}",
    "devUrl": "{{TAURI_DEV_URL}}",
    "frontendDist": "{{TAURI_FRONTEND_DIST}}"
  },
  "app": {
    "windows": [
      {
        "title": "{{PROJECT_NAME}}",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
